{
  "sample_percentages": [0.12, 0.5, 0.88],
  "review_background": "#ffffff",
  "sheet_background": "#f7f7f7",
  "tile_background": "#ffffff",
  "promoted_video_extensions": [".webm", ".mp4", ".mov", ".mkv"],
  "ignore_path_segments": [".manim", "partial_movie_files"],
  "proof_frame_defaults": {
    "compression": "sample the constrained mid-state",
    "capture": "sample where the mechanism is still visible around the leader",
    "handoff": "sample the transfer frame",
    "snap": "sample the stressed or overshoot frame before the landing",
    "support_force": "sample where the support visibly causes the motion",
    "landing": "sample both the designed landing and the resolved final hold"
  },
  "composition_audit": {
    "cadence_seconds": 0.5,
    "minimum_margin_fraction": 0.045,
    "center_tolerance_fraction": 0.08,
    "blocking_codes": [
      "blank_frame",
      "low_visual_margin",
      "off_center_content"
    ],
    "notice_codes": [
      "stray_vertical_fragment",
      "possible_overlap_or_crowding"
    ]
  },
  "crowding_audit": {
    "cadence_seconds": 0.5,
    "minimum_clearance_px": 30,
    "blocking_code": "low_component_clearance",
    "blocking_pairs": [
      "actor-guide",
      "actor-outline",
      "actor-actor"
    ],
    "visual_review_pairs": [
      "actor-support"
    ]
  }
}
